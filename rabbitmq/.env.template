# This environment variable is used to let the container be discovered by nginx-proxy to map the virtual hosts and
# ports for the RabbitMQ server.
#
# Only HTTP(S) services can be reverse-proxied here. The management UI is on 15672; AMQP (5672) is not HTTP — clients
# use docker compose published port 5672 or hostname userver-rabbitmq:5672 on the nginx-proxy network, not this map.
# JSON must not repeat the same hostname key twice (the second entry would overwrite the first).
#
# Default:
VIRTUAL_HOST_MULTIPORTS={"rabbitmq.sd40.lan":{"/":{"port":15672,"proto":"http","dest":""}}}

# TLS with userver-web acme-companion: set DEFAULT_EMAIL once in letsencrypt/.env; avoid repeating the
# same LETSENCRYPT_EMAIL on every backend (acme-companion concatenates them and breaks registration).

# This environment variable is used to set the deployment ID for the RabbitMQ server.
DEPLOYMENT_ID=sd40-2

# This environment variable is only meant to be used in development and CI environments. This has the same meaning as
# default_user in rabbitmq.conf but higher priority. This option may be more convenient in cases where providing a
# config file is impossible, and environment variables is the only way to seed a user.
# Default: (none)
RABBITMQ_DEFAULT_USER=user

# This environment variable is only meant to be used in development and CI environments. This has the same meaning as
# default_pass in rabbitmq.conf but higher priority. This option may be more convenient in cases where providing a
# config file is impossible, and environment variables is the only way to seed a user.
# Default: (none)
RABBITMQ_DEFAULT_PASS=password

# This environment variable is only meant to be used in development and CI environments. This has the same meaning as
# default_vhost in rabbitmq.conf but higher priority. This option may be more convenient in cases where providing a
# config file is impossible, and environment variables is the only way to seed users and virtual hosts.
# Default: (none)
RABBITMQ_DEFAULT_VHOST=

# Change this if you only want to bind to one network interface. Binding to two or more interfaces can be set up in the
# configuration file.
# Default: an empty string, meaning "bind to all network interfaces".
RABBITMQ_NODE_IP_ADDRESS=

# See Networking guide for more information on ports used by various parts of RabbitMQ.
# Default: 5672.
RABBITMQ_NODE_PORT=5672

# Port used for inter-node and CLI tool communication. Ignored if rabbitmq.conf sets
# distribution.listener.port_range.min or distribution.listener.port_range.max.
# Default: RABBITMQ_NODE_PORT + 20000
RABBITMQ_DIST_PORT=25672

# This limit corresponds to the maximum open file handle limit in the kernel. When the latter is set to a value higher
# than 65536, ERL_MAX_PORT must be adjusted accordingly.
# Default: 65536
ERL_MAX_PORTS=65536

# Interface(s) used by epmd, a component in inter-node and CLI tool communication.
# Default: all available interfaces, both IPv6 and IPv4.
ERL_EPMD_ADDRESS=

# Port used by epmd, a component in inter-node and CLI tool communication.
# Default: 4369
ERL_EPMD_PORT=4369

# Outgoing data buffer size limit to use for inter-node communication connections, in kilobytes. Values lower than 64
# MB are not recommended.
# Default: 128000
RABBITMQ_DISTRIBUTION_BUFFER_SIZE=128000

# The node name should be unique per Erlang-node-and-machine combination. To run multiple nodes, see the clustering
# guide.
# The part after @ must resolve inside the container (epmd). docker-compose sets hostname: rabbitmq for this service.
# Default:
#  Unix:* rabbit@$HOSTNAME
#  Windows: rabbit@%COMPUTERNAME%
RABBITMQ_NODENAME=rabbit@rabbitmq
